---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'Tecnik | Consultoría tecnológica para pequeños negocios';
const pageDescription =
  'Consultoría tecnológica en Elche. Webs, tiendas online, automatizaciones con IA. Trato directo y precios claros.';

const testimonials = [
  {
    text: 'En una semana teníamos web nueva y empezaron a entrar contactos desde Google.',
    author: 'Laura M.',
    role: 'Clínica estética, Elche'
  },
  {
    text: 'Automatizamos respuestas y ahora atendemos clientes sin estar pegados al móvil todo el día.',
    author: 'Carlos R.',
    role: 'Tienda de deporte'
  },
  {
    text: 'Nos explicó todo claro, sin tecnicismos. Sabíamos precio y plazos desde el primer día.',
    author: 'Marta P.',
    role: 'Centro de fisioterapia'
  },
  {
    text: 'Pasamos de cero presencia online a recibir solicitudes cada semana desde la web.',
    author: 'David S.',
    role: 'Reformas integrales'
  },
  {
    text: 'La automatización de presupuestos nos ahorra horas todas las semanas.',
    author: 'Ana V.',
    role: 'Estudio de interiorismo'
  },
  {
    text: 'Mejoramos tiempos de respuesta y la sensación de profesionalidad con una web mucho más moderna.',
    author: 'Sergio T.',
    role: 'Asesoría local'
  },
  {
    text: 'Nos propuso solo lo que necesitábamos. Sin vender humo y con resultados rápidos.',
    author: 'Patricia G.',
    role: 'Negocio familiar'
  }
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <!-- Navegación principal con CTA fijo -->
  <header class="navbar" id="inicio">
    <div class="container nav-inner">
      <a class="logo" href="#inicio">Tecnik</a>
      <nav class="nav-links" aria-label="Principal">
        <a href="#servicios">Servicios</a>
        <a href="#ia">IA</a>
        <a href="#como-trabajo">Cómo trabajamos</a>
        <a href="#precios">Precios</a>
        <a href="#contacto">Contacto</a>
      </nav>
      <a class="btn btn-primary nav-cta" href="#contacto">Hablemos</a>
    </div>
  </header>

  <main>
    <!-- Bloque principal de conversión -->
    <section class="hero section reveal">
      <div class="container hero-content">
        <div class="hero-copy">
          <h1>Tu negocio, con tecnología que funciona de verdad</h1>
          <p>
            Webs, tiendas online y automatizaciones para autónomos y pequeños negocios. Sin tecnicismos,
            sin letra pequeña.
          </p>
          <div class="hero-actions">
            <a class="btn btn-primary" href="#servicios">Ver servicios</a>
            <a class="btn btn-secondary" href="#contacto">Contactar</a>
          </div>
        </div>

        <div class="hero-visual" aria-hidden="true">
          <img class="hero-image" src="/hero-workflow.png" alt="Flujo de trabajo tecnológico" decoding="async" />
        </div>
      </div>
    </section>

    <!-- Beneficios diferenciales -->
    <section class="section reveal" aria-labelledby="valor-title">
      <div class="container">
        <h2 id="valor-title">¿Por qué Tecnik?</h2>
        <div class="grid grid-3">
          <article class="card">
            <h3>🎯 Trato directo</h3>
            <p>Hablas siempre conmigo, no con un comercial. Entiendo tu negocio antes de proponer nada.</p>
          </article>
          <article class="card">
            <h3>⚡ Entrega rápida</h3>
            <p>
              La mayoría de proyectos en 1-2 semanas. Sin esperas eternas ni presupuestos que no llegan.
            </p>
          </article>
          <article class="card">
            <h3>🤖 Listo para la IA</h3>
            <p>
              Te ayudo a incorporar inteligencia artificial en tu negocio de forma práctica: sin
              tecnicismos, con resultados visibles desde el primer día.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- Catálogo de servicios -->
    <section class="section reveal" id="servicios" aria-labelledby="servicios-title">
      <div class="container">
        <h2 id="servicios-title">¿Qué puedo hacer por ti?</h2>
        <p class="section-subtitle">Servicios pensados para negocios reales, no para grandes empresas.</p>
        <div class="grid services-grid">
          <article class="card service-card"><h3>🌐 Página Web</h3><p>Tu negocio con presencia profesional online. Diseño moderno, rápida y adaptada a móvil.</p><strong>Desde 350€</strong></article>
          <article class="card service-card"><h3>🛒 Tienda Online</h3><p>Vende en internet sin complicaciones. Con Shopify o WooCommerce según tu caso.</p><strong>Desde 700€</strong></article>
          <article class="card service-card"><h3>⚙️ Automatizaciones e IA</h3><p>Flujos inteligentes, agentes de atención al cliente, respuestas automáticas e informes generados automáticamente. Tu negocio trabajando solo.</p><strong>Desde 150€</strong></article>
          <article class="card service-card"><h3>📈 SEO Local</h3><p>Aparece cuando alguien en Elche busca lo que tu ofreces.</p><strong>Desde 200€</strong></article>
          <article class="card service-card"><h3>🗄️ CRM para autónomos</h3><p>Gestiona tus clientes y seguimientos sin Excel ni post-its.</p><strong>Desde 300€</strong></article>
          <article class="card service-card"><h3>🔧 Mantenimiento</h3><p>Tu web siempre actualizada y funcionando.</p><strong>Desde 30€/mes</strong></article>
          <article class="card service-card"><h3>🧠 Modernización con IA</h3><p>Incorpora inteligencia artificial a tu negocio: atiende clientes automáticamente, genera contenido, analiza datos y toma mejores decisiones.</p><strong>Desde 400€</strong></article>
        </div>
      </div>
    </section>

    <!-- Opiniones -->
    <section class="section reveal testimonials-section" aria-labelledby="opiniones-title">
      <div class="container">
        <h2 id="opiniones-title">Lo que dicen clientes como tú</h2>
        <p class="section-subtitle">Opiniones de negocios locales que han modernizado su operativa con Tecnik.</p>
        <div class="testimonials-carousel" data-carousel>
          <div class="testimonials-track" data-carousel-track>
            {testimonials.map((testimonial) => (
              <article class="testimonial-card" data-carousel-item>
                <p class="testimonial-quote">"{testimonial.text}"</p>
                <p class="testimonial-author">{testimonial.author}</p>
                <p class="testimonial-role">{testimonial.role}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Oportunidades prácticas de IA -->
    <section class="section section-ia reveal" id="ia" aria-labelledby="ia-title">
      <div class="container">
        <h2 id="ia-title">¿Tu negocio ya aprovecha la inteligencia artificial?</h2>
        <p class="section-subtitle">
          La IA no es solo para grandes empresas. Hoy cualquier autónomo o pequeño negocio puede
          automatizar tareas, atender clientes y tomar mejores decisiones, sin necesidad de un equipo de
          tecnología.
        </p>
        <div class="grid ia-grid">
          <article class="card ia-card">
            <h3>💬 Atención al cliente 24/7</h3>
            <p>
              Un asistente inteligente que responde las preguntas más frecuentes de tus clientes en tu web
              o WhatsApp, en cualquier momento, sin que tengas que estar pendiente.
            </p>
          </article>
          <article class="card ia-card">
            <h3>📊 Informes automáticos</h3>
            <p>
              Recibe cada semana un resumen de tus ventas, reservas o métricas clave directamente en tu
              email, generado y enviado de forma automática.
            </p>
          </article>
          <article class="card ia-card">
            <h3>🔄 Procesos que se gestionan solos</h3>
            <p>
              Confirmación de citas, envío de presupuestos, recordatorios a clientes... Automatiza lo
              repetitivo y dedica tu tiempo a lo que realmente importa.
            </p>
          </article>
        </div>
        <div class="ia-cta">
          <p>¿Quieres ver cómo aplicaría esto en tu negocio concreto?</p>
          <a class="btn btn-primary" href="#contacto">Hablemos</a>
        </div>
      </div>
    </section>

    <!-- Oferta principal destacada -->
    <section class="section reveal pack-section" aria-labelledby="pack-title">
      <div class="container pack-card">
        <span class="pack-badge">Mas popular</span>
        <h2 id="pack-title">Pack Starter - 550€</h2>
        <p>Todo lo que necesita un negocio para empezar bien:</p>
        <ul>
          <li>✓ Web profesional de 3-5 paginas</li>
          <li>✓ Formulario de contacto con notificacion automatica a WhatsApp</li>
          <li>✓ Google Business Profile configurado y optimizado</li>
          <li>✓ 1 mes de soporte incluido</li>
        </ul>
        <a class="btn btn-light" href="#contacto">Quiero este pack</a>
      </div>
    </section>

    <!-- Proceso de trabajo -->
    <section class="section reveal" id="como-trabajo" aria-labelledby="proceso-title">
      <div class="container">
        <h2 id="proceso-title">Sin sorpresas. Así es el proceso:</h2>
        <div class="process-grid">
          <article class="process-step"><span>1</span><h3>Diagnóstico</h3><p>Me cuentas qué necesitas. Sin compromiso, sin presupuestos automáticos.</p></article>
          <article class="process-step"><span>2</span><h3>Estrategia</h3><p>En 24-48h tienes una propuesta clara con precio cerrado.</p></article>
          <article class="process-step"><span>3</span><h3>Desarrollo</h3><p>Trabajamos juntos hasta que quedes satisfecho.</p></article>
          <article class="process-step"><span>4</span><h3>Soporte</h3><p>Entrego y me quedo disponible si necesitas ajustes.</p></article>
        </div>
      </div>
    </section>

    <!-- Estructura de precios -->
    <section class="section reveal" id="precios" aria-labelledby="precios-title">
      <div class="container">
        <h2 id="precios-title">Precios claros, sin letra pequeña</h2>
        <p class="section-subtitle">Precio cerrado desde el principio. Sin sorpresas.</p>
        <div class="grid pricing-grid">
          <article class="card">
            <h3>Proyectos (pago único)</h3>
            <ul>
              <li>Web básica: desde 350€</li>
              <li>Landing page: desde 250€</li>
              <li>Tienda online: desde 700€</li>
              <li>Automatización: desde 150€</li>
              <li>SEO local: desde 200€</li>
              <li>CRM autónomo: desde 300€</li>
            </ul>
          </article>
          <article class="card">
            <h3>Mantenimiento (mensual)</h3>
            <ul>
              <li>Web: 30-50€/mes</li>
              <li>Tienda: 50-80€/mes</li>
              <li>Automatizaciones: 30-60€/mes</li>
              <li>Contenido SEO: 100-200€/mes</li>
            </ul>
          </article>
          <article class="card note-card">
            <h3>A medida</h3>
            <p>¿No encuentras lo que buscas? Cuéntame tu caso y te doy precio.</p>
            <a class="btn btn-secondary" href="#contacto">Pedir presupuesto</a>
          </article>
        </div>
      </div>
    </section>

    <!-- Formulario preparado para Netlify Forms -->
    <section class="section reveal" id="contacto" aria-labelledby="contacto-title">
      <div class="container contact-grid">
        <div>
          <h2 id="contacto-title">¿Hablamos?</h2>
          <p class="section-subtitle">Cuéntame qué necesitas. Te respondo en menos de 24 horas.</p>
          <form
            class="contact-form"
            name="contacto"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            autocomplete="off"
            novalidate
          >
            <input type="hidden" name="form-name" value="contacto" />
            <input type="hidden" name="subject" value="Alguien quiere más información" />
            <input type="hidden" name="to" value="hola@tecnik.studio" />
            <input type="hidden" name="_timestamp" id="form-timestamp" />
            <input type="text" name="_honeypot" style="display:none" tabindex="-1" autocomplete="off" />
            <p class="hidden-field">
              <label>
                No rellenar: <input name="bot-field" />
              </label>
            </p>

            <label for="nombre">Nombre</label>
            <input id="nombre" name="nombre" type="text" required />
            <p id="nombre-error" class="field-error" aria-live="polite"></p>

            <label for="email">Email</label>
            <input id="email" name="email" type="email" required />
            <p id="email-error" class="field-error" aria-live="polite"></p>

            <label for="telefono">Teléfono (opcional)</label>
            <input id="telefono" name="telefono" type="tel" />

            <label for="servicio">¿Qué necesitas?</label>
            <select id="servicio" name="servicio" required>
              <option value="">Selecciona una opción</option>
              <option>Web</option>
              <option>Tienda online</option>
              <option>Automatización</option>
              <option>SEO</option>
              <option>Mantenimiento</option>
              <option>Otro</option>
            </select>

            <label for="mensaje">Mensaje</label>
            <textarea id="mensaje" name="mensaje" rows="5" required></textarea>
            <p id="mensaje-error" class="field-error" aria-live="polite"></p>

            <p id="contact-status" class="contact-status" aria-live="polite"></p>

            <button class="btn btn-primary" type="submit">Enviar mensaje</button>
          </form>
        </div>

        <aside class="contact-info">
          <p>📧 hola@tecnik.studio</p>
          <p>📍 Elche, Alicante</p>
          <p>También puedes escribirme directamente al email si lo prefieres.</p>
        </aside>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-content">
      <a class="logo" href="#inicio">Tecnik</a>
      <p>© 2025 Tecnik · Elche, Alicante</p>
      <nav aria-label="Footer">
        <a href="#servicios">Servicios</a>
        <a href="#contacto">Contacto</a>
        <a href="/privacidad">Privacidad</a>
      </nav>
      <small>Consultoria tecnologica para pequeños negocios</small>
    </div>
  </footer>

  <script>
    document.getElementById('form-timestamp').value = Date.now().toString();

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      },
      { threshold: 0.15 }
    );

    document.querySelectorAll('.reveal').forEach((section) => observer.observe(section));

    const carousel = document.querySelector('[data-carousel]');
    const carouselTrack = document.querySelector('[data-carousel-track]');
    const carouselItems = Array.from(document.querySelectorAll('[data-carousel-item]'));

    if (carousel instanceof HTMLElement && carouselTrack instanceof HTMLElement && carouselItems.length > 1) {
      let currentIndex = 0;
      let intervalId;
      let isPaused = false;

      const getScrollDistance = () => {
        const firstCard = carouselItems[0];
        const secondCard = carouselItems[1];
        if (!(firstCard instanceof HTMLElement)) return 0;
        if (!(secondCard instanceof HTMLElement)) return firstCard.offsetWidth;
        return Math.abs(secondCard.offsetLeft - firstCard.offsetLeft);
      };

      const goToIndex = (index, behavior = 'smooth') => {
        const clamped = Math.max(0, Math.min(index, carouselItems.length - 1));
        const distance = getScrollDistance();
        currentIndex = clamped;
        carouselTrack.scrollTo({
          left: distance * clamped,
          behavior
        });
      };

      const startAutoPlay = () => {
        if (intervalId) clearInterval(intervalId);
        intervalId = window.setInterval(() => {
          if (isPaused) return;
          const nextIndex = (currentIndex + 1) % carouselItems.length;
          goToIndex(nextIndex);
        }, 4200);
      };

      const syncCurrentIndex = () => {
        const distance = getScrollDistance();
        if (distance <= 0) return;
        currentIndex = Math.round(carouselTrack.scrollLeft / distance);
      };

      const pause = () => {
        isPaused = true;
      };

      const resume = () => {
        isPaused = false;
      };

      carousel.addEventListener('mouseenter', pause);
      carousel.addEventListener('mouseleave', resume);
      carousel.addEventListener('focusin', pause);
      carousel.addEventListener('focusout', resume);
      carouselTrack.addEventListener('touchstart', pause, { passive: true });
      carouselTrack.addEventListener('touchend', resume, { passive: true });
      carouselTrack.addEventListener('pointerdown', pause);
      carouselTrack.addEventListener('pointerup', resume);
      carouselTrack.addEventListener('scroll', syncCurrentIndex, { passive: true });
      window.addEventListener('resize', () => goToIndex(currentIndex, 'auto'));

      startAutoPlay();
    }

    const contactForm = document.querySelector('.contact-form');

    if (contactForm instanceof HTMLFormElement) {
      const minSubmitDelayMs = 3000;
      const nombreInput = contactForm.querySelector('#nombre');
      const emailInput = contactForm.querySelector('#email');
      const telefonoInput = contactForm.querySelector('#telefono');
      const servicioInput = contactForm.querySelector('#servicio');
      const mensajeInput = contactForm.querySelector('#mensaje');
      const honeypotInput = contactForm.querySelector('input[name="_honeypot"]');
      const timestampInput = contactForm.querySelector('#form-timestamp');
      const nombreError = contactForm.querySelector('#nombre-error');
      const emailError = contactForm.querySelector('#email-error');
      const mensajeError = contactForm.querySelector('#mensaje-error');
      const statusNode = contactForm.querySelector('#contact-status');
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

      contactForm.addEventListener('submit', (event) => {
        event.preventDefault();

        const clearErrors = [nombreError, emailError, mensajeError];
        clearErrors.forEach((errorNode) => {
          if (errorNode instanceof HTMLElement) errorNode.textContent = '';
        });

        if (statusNode instanceof HTMLElement) {
          statusNode.textContent = '';
          statusNode.classList.remove('contact-status--success', 'contact-status--error');
        }

        if (honeypotInput instanceof HTMLInputElement && honeypotInput.value.trim() !== '') {
          return;
        }

        if (!(timestampInput instanceof HTMLInputElement)) {
          return;
        }

        const startedAt = Number(timestampInput.value || 0);
        if (!Number.isFinite(startedAt) || Date.now() - startedAt < minSubmitDelayMs) {
          return;
        }

        let hasError = false;

        if (nombreInput instanceof HTMLInputElement && nombreInput.value.trim().length < 2) {
          if (nombreError instanceof HTMLElement) nombreError.textContent = 'El nombre debe tener al menos 2 caracteres.';
          hasError = true;
        }

        if (emailInput instanceof HTMLInputElement && !emailRegex.test(emailInput.value.trim())) {
          if (emailError instanceof HTMLElement) emailError.textContent = 'Introduce un email válido.';
          hasError = true;
        }

        if (mensajeInput instanceof HTMLTextAreaElement && mensajeInput.value.trim().length < 10) {
          if (mensajeError instanceof HTMLElement) mensajeError.textContent = 'El mensaje debe tener al menos 10 caracteres.';
          hasError = true;
        }

        if (hasError) return;

        const payload = {
          nombre: nombreInput instanceof HTMLInputElement ? nombreInput.value.trim() : '',
          email: emailInput instanceof HTMLInputElement ? emailInput.value.trim() : '',
          telefono: telefonoInput instanceof HTMLInputElement ? telefonoInput.value.trim() : '',
          servicio: servicioInput instanceof HTMLSelectElement ? servicioInput.value : '',
          mensaje: mensajeInput instanceof HTMLTextAreaElement ? mensajeInput.value.trim() : ''
        };

        if (statusNode instanceof HTMLElement) {
          statusNode.textContent = 'Enviando...';
          statusNode.classList.remove('contact-status--success', 'contact-status--error');
        }

        fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        })
          .then(async (res) => {
            const data = await res.json().catch(() => null);
            if (res.ok && data && data.success) return;

            const serverError = data && typeof data.error === 'string' ? data.error : 'No se pudo enviar.';
            throw new Error(serverError);
          })
          .then(() => {
            if (!(statusNode instanceof HTMLElement)) return;
            statusNode.textContent = 'Mensaje enviado correctamente. Gracias por contactar con Tecnik.';
            statusNode.classList.add('contact-status--success');
          })
          .catch((err) => {
            if (!(statusNode instanceof HTMLElement)) return;
            statusNode.textContent = `Error al enviar el mensaje: ${err?.message || 'Inténtalo de nuevo.'}`;
            statusNode.classList.add('contact-status--error');
          });
      });
    }
  </script>
</BaseLayout>
