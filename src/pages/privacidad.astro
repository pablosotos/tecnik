---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'Política de privacidad | Tecnik';
const pageDescription = 'Información sobre privacidad, cookies y protección de datos en Tecnik.';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <main class="privacy-page">
    <div class="privacy-container">
      <h1>Política de privacidad</h1>

      <section>
        <h2>Responsable del tratamiento</h2>
        <p><strong>Tecnik</strong></p>
        <p>Elche (Alicante), España</p>
        <p>Email: <a href="mailto:hola@tecnik.studio">hola@tecnik.studio</a></p>
      </section>

      <section>
        <h2>Datos que se recogen</h2>
        <p>En esta web se recogen:</p>
        <ul>
          <li>Datos enviados mediante formulario de contacto: nombre, email, teléfono y mensaje.</li>
          <li>Datos de uso y navegación con fines analíticos, solo si aceptas cookies analíticas.</li>
        </ul>
      </section>

      <section>
        <h2>Finalidad del tratamiento</h2>
        <ul>
          <li>Responder a consultas y solicitudes enviadas desde el formulario de contacto.</li>
          <li>Medir el tráfico y uso de la web para mejorar contenidos y experiencia.</li>
        </ul>
      </section>

      <section>
        <h2>Terceros</h2>
        <p>
          Para analítica se utiliza Google Analytics 4 (Google LLC), únicamente cuando se ha dado
          consentimiento para cookies analíticas.
        </p>
        <p>
          Puedes consultar su política de privacidad en
          <a href="https://policies.google.com/privacy" rel="noopener noreferrer" target="_blank">
            https://policies.google.com/privacy
          </a>.
        </p>
      </section>

      <section>
        <h2>Base legal</h2>
        <p>
          El tratamiento de datos del formulario se basa en tu solicitud de contacto. El tratamiento de
          datos analíticos se basa en tu consentimiento.
        </p>
      </section>

      <section>
        <h2>Derechos RGPD</h2>
        <p>Puedes ejercer tus derechos de:</p>
        <ul>
          <li>Acceso</li>
          <li>Rectificación</li>
          <li>Supresión</li>
          <li>Portabilidad</li>
          <li>Oposición</li>
        </ul>
      </section>

      <section>
        <h2>Cómo ejercer tus derechos</h2>
        <p>
          Puedes solicitar el ejercicio de tus derechos enviando un email a
          <a href="mailto:hola@tecnik.studio">hola@tecnik.studio</a>.
        </p>
      </section>
    </div>
  </main>
</BaseLayout>

